# Application
APP_ENV=development
LOG_LEVEL=INFO

# Service ports
WEB_APP_PORT=5000
AUTH_SERVICE_PORT=5001
TRANSACTION_SERVICE_PORT=5002

# Service URLs used by web-app
AUTH_SERVICE_URL=http://127.0.0.1:5001
TRANSACTION_SERVICE_URL=http://127.0.0.1:5002
SERVICE_TIMEOUT_SECONDS=5

# Databases
AUTH_DATABASE_URL=postgresql://postgres:your_password@localhost:5432/spendwise_auth_db
TRANSACTION_DATABASE_URL=postgresql://postgres:your_password@localhost:5432/spendwise_transaction_db

# Docker Compose PostgreSQL
POSTGRES_USER=spendwise_user
POSTGRES_PASSWORD=spendwise_password
POSTGRES_HOST_PORT=5433

# Docker Compose host ports
WEB_APP_HOST_PORT=5000
AUTH_SERVICE_HOST_PORT=5001
TRANSACTION_SERVICE_HOST_PORT=5002

# Security
SECRET_KEY=change-me
JWT_SECRET=change-me
JWT_EXPIRES_MINUTES=120

# Session cookies
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
