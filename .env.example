# Optional local Docker Compose settings.
# Copy this file to .env only if you want to change the defaults.

APP_ENV=production
LOG_LEVEL=INFO

POSTGRES_USER=spendwise_user
POSTGRES_PASSWORD=spendwise_password

WEB_APP_HOST_PORT=8000

SECRET_KEY=change-this-local-secret
JWT_SECRET=change-this-local-jwt-secret
JWT_EXPIRES_MINUTES=120

SERVICE_TIMEOUT_SECONDS=5
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
